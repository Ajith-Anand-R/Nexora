datasource db {
  provider = "sqlite"
  url      = "file:../transitops.db"
}

generator client {
  provider = "prisma-client-js"
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  roleId       Int
  role         Role     @relation(fields: [roleId], references: [id])
  createdAt    DateTime @default(now())
}

model Vehicle {
  id                 Int              @id @default(autoincrement())
  registrationNumber String           @unique
  nameModel          String
  type               String
  maxLoadCapacity    Float
  odometer           Float
  acquisitionCost    Float
  region             String
  status             String
  createdAt          DateTime         @default(now())
  trips              Trip[]
  maintenanceLogs    MaintenanceLog[]
  fuelLogs           FuelLog[]
  expenses           Expense[]
}

model Driver {
  id                 Int      @id @default(autoincrement())
  name               String
  licenseNumber      String   @unique
  licenseCategory    String
  licenseExpiryDate  DateTime
  contactNumber      String
  safetyScore        Float    @default(100.0)
  status             String
  createdAt          DateTime @default(now())
  trips              Trip[]
}

model Trip {
  id              Int       @id @default(autoincrement())
  source          String
  destination     String
  vehicleId       Int
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])
  driverId        Int
  driver          Driver    @relation(fields: [driverId], references: [id])
  cargoWeight     Float
  plannedDistance Float
  actualDistance  Float?
  fuelConsumed    Float?
  status          String
  createdAt       DateTime  @default(now())
  dispatchedAt    DateTime?
  completedAt     DateTime?
  fuelLogs        FuelLog[]
}

model MaintenanceLog {
  id          Int       @id @default(autoincrement())
  vehicleId   Int
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
  description String
  cost        Float
  status      String
  startDate   DateTime  @default(now())
  endDate     DateTime?
}

model FuelLog {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  tripId    Int?
  trip      Trip?    @relation(fields: [tripId], references: [id])
  liters    Float
  cost      Float
  date      DateTime @default(now())
}

model Expense {
  id          Int      @id @default(autoincrement())
  vehicleId   Int
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  category    String
  amount      Float
  date        DateTime @default(now())
  description String
}
